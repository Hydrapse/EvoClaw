# direnv config for EvoClaw — non-secret project defaults.
# Safe to commit: contains no API keys, only routing hints for the harness
# and Claude Code session running inside this repo.

# Route Claude Code's "haiku slot" (subagent / skills / auto-memory /
# context management) to opus-4-7 instead of the upstream Haiku default.
# Reason: matches the model running in this repo's trials, keeps cost
# accounting consistent, and avoids hitting Anthropic Haiku when the
# user's UNIFIED_BASE_URL points at a non-Anthropic proxy.
export ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-opus-4-7
